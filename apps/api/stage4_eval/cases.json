{
  "manifest_version": "stage4-slice1-v1",
  "schema_version": "1.0",
  "description": "Stage 4 Slice 1 fixed practice eval. Hard cases gate the deterministic Exercise Author / Answer Grader contracts and the privacy/deletion/scope boundaries; observational cases record non-gating metrics. Probes drive the real practice code with a fake provider (offline).",
  "cases": [
    {"id": "gen_mixed_types", "role": "exercise_author", "behavior": "生成混合题型集合并提交", "gate": "hard", "risk": "引用必须来自来源快照", "expects": "committed_with_snapshot_citations"},
    {"id": "gen_single", "role": "exercise_author", "behavior": "生成单题集合", "gate": "hard", "risk": "1 题允许单一题型", "expects": "committed"},
    {"id": "gen_english", "role": "exercise_author", "behavior": "英文生成语言一致", "gate": "hard", "risk": "语言不得漂移", "expects": "language_carried"},
    {"id": "gen_no_evidence", "role": "exercise_author", "behavior": "证据不足不提交", "gate": "hard", "risk": "不得生成 fallback 题", "expects": "no_commit"},
    {"id": "gen_unknown_citation", "role": "exercise_author", "behavior": "未知引用不提交", "gate": "hard", "risk": "校验失败不得落库", "expects": "no_commit"},
    {"id": "gen_invalid_rubric", "role": "exercise_author", "behavior": "非法 rubric 不提交", "gate": "hard", "risk": "权重须合计 100", "expects": "no_commit"},
    {"id": "gen_budget", "role": "exercise_author", "behavior": "预算耗尽不提交", "gate": "hard", "risk": "不得截断为成功", "expects": "no_commit"},
    {"id": "gen_cancel", "role": "exercise_author", "behavior": "取消不提交", "gate": "hard", "risk": "晚到结果不得复活", "expects": "no_commit"},
    {"id": "gen_prompt_injection_bounded", "role": "exercise_author", "behavior": "注入不扩大 scope", "gate": "hard", "risk": "工具/题数/范围不得被输入改写", "expects": "scope_unchanged"},
    {"id": "gen_multi_search_distinct_keys", "role": "exercise_author", "behavior": "多检索跨次唯一 citation key", "gate": "hard", "risk": "key 重叠覆盖映射", "expects": "distinct_stable_keys"},
    {"id": "gen_plan_call_counted", "role": "exercise_author", "behavior": "plan call 计入 step 与 trace", "gate": "hard", "risk": "预算统计漏 plan", "expects": "plan_counted"},
    {"id": "gen_final_authority_mutation", "role": "exercise_author", "behavior": "最终权威突变丢弃晚到结果", "gate": "hard", "risk": "来源途中失效仍提交", "expects": "no_commit"},
    {"id": "single_correct", "role": "practice", "behavior": "单选正确确定性评分", "gate": "hard", "risk": "不调用 provider", "expects": "score_100_no_provider"},
    {"id": "single_incorrect", "role": "practice", "behavior": "单选错误确定性评分", "gate": "hard", "risk": "分数为 0", "expects": "score_0"},
    {"id": "single_answer_hidden", "role": "practice", "behavior": "提交前不泄露答案", "gate": "hard", "risk": "answer_spec/rubric/correct 不可见", "expects": "no_leak"},
    {"id": "grade_ungradable", "role": "answer_grader", "behavior": "无法评分不伪造分数", "gate": "hard", "risk": "不得固定 50 分", "expects": "no_score"},
    {"id": "grade_graded_verdict", "role": "answer_grader", "behavior": "可评分返回 verdict 与分数", "gate": "hard", "risk": "rubric 分项须齐全", "expects": "scored"},
    {"id": "grade_repair", "role": "answer_grader", "behavior": "结构修复后提交", "gate": "hard", "risk": "最多一次修复", "expects": "feedback_committed"},
    {"id": "grade_failure", "role": "answer_grader", "behavior": "修复仍失败不提交 Feedback", "gate": "hard", "risk": "不得伪造成功", "expects": "no_feedback"},
    {"id": "grade_answer_too_large", "role": "answer_grader", "behavior": "答案过长被拒", "gate": "hard", "risk": "answer_too_large", "expects": "rejected"},
    {"id": "grade_no_retrieval", "role": "answer_grader", "behavior": "评分不检索", "gate": "hard", "risk": "评分不扩大证据", "expects": "no_search"},
    {"id": "runtime_idempotent", "role": "practice", "behavior": "幂等创建与提交", "gate": "hard", "risk": "重复请求返回原资源", "expects": "idempotent"},
    {"id": "scope_workspace_isolation", "role": "practice", "behavior": "Workspace 隔离", "gate": "hard", "risk": "跨 Workspace 不可读", "expects": "isolated"},
    {"id": "scope_source_degraded", "role": "practice", "behavior": "来源降级阻止新生成并保留历史", "gate": "hard", "risk": "不得静默切换来源", "expects": "blocked_history_kept"},
    {"id": "delete_attempt_and_set", "role": "practice", "behavior": "删除后不可读答案与反馈", "gate": "hard", "risk": "删除不彻底", "expects": "unreadable"},
    {"id": "language_consistency", "role": "cross", "behavior": "请求与评分语言一致", "gate": "hard", "risk": "语言漂移", "expects": "language_carried"},
    {"id": "privacy_trace_clean", "role": "practice", "behavior": "trace 不含答案/rubric", "gate": "hard", "risk": "敏感字段入 trace", "expects": "clean_trace"},
    {"id": "obs_generation", "role": "exercise_author", "behavior": "生成观察指标", "gate": "observational", "risk": "无普适阈值", "expects": "metrics_recorded"},
    {"id": "obs_grading", "role": "answer_grader", "behavior": "评分观察指标", "gate": "observational", "risk": "无普适阈值", "expects": "metrics_recorded"},
    {"id": "lp_one_error_provisional", "role": "practice", "behavior": "一次错误仅 provisional", "gate": "hard", "risk": "单次污染", "expects": "provisional_no_memory"},
    {"id": "lp_two_errors_confirmed_memory", "role": "practice", "behavior": "两次不同题错误确认 Weakness 并建 Memory", "gate": "hard", "risk": "确认条件不足", "expects": "confirmed_one_memory"},
    {"id": "lp_idempotent_replay", "role": "practice", "behavior": "Feedback 重放不产生重复事件", "gate": "hard", "risk": "重复 event/signal", "expects": "no_duplicates"},
    {"id": "lp_memory_suppression", "role": "practice", "behavior": "删除 Memory 后旧事件不复活", "gate": "hard", "risk": "旧证据复活", "expects": "suppressed"},
    {"id": "lp_ungradable_no_signal", "role": "practice", "behavior": "ungradable 不产生 signal", "gate": "hard", "risk": "无效证据入 mastery", "expects": "no_signal"},
    {"id": "lp_review_no_mastery", "role": "practice", "behavior": "标记已复习不提高 mastery", "gate": "hard", "risk": "操作等于验证", "expects": "band_unchanged"},
    {"id": "lp_api_no_leak", "role": "practice", "behavior": "API 不泄露 projection_score/答案", "gate": "hard", "risk": "内部值公开", "expects": "safe_projection"},
    {"id": "lp_policy_default_off", "role": "practice", "behavior": "Memory policy 默认关闭", "gate": "hard", "risk": "默认外发", "expects": "default_off"},
    {"id": "obs_lp_coverage", "role": "practice", "behavior": "掌握度覆盖观察指标", "gate": "observational", "risk": "无普适阈值", "expects": "metrics_recorded"}
  ]
}
