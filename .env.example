# ============================================================================
# HelloAgents 统一环境变量配置文件
# ============================================================================
# 复制此文件为 .env 并填入你的API密钥
# 系统要求：Python 3.10+ （必需）

# ============================================================================
# 🚀 统一配置格式（推荐）- 框架自动检测provider
# ============================================================================
# 只需配置以下4个通用环境变量，框架会自动识别LLM提供商：

# 模型名称
LLM_MODEL_ID=your-model-name

# API密钥
LLM_API_KEY=your-api-key-here

# 服务地址
LLM_BASE_URL=your-api-base-url

# 超时时间（可选，默认60秒）
LLM_TIMEOUT=60

# ============================================================================
# 🛠️ 工具配置（可选）
# ============================================================================

# Tavily搜索（推荐）- 获取API密钥：https://tavily.com/
# TAVILY_API_KEY=tvly-your_tavily_key_here

# SerpApi搜索（备选）- 获取API密钥：https://serpapi.com/
# SERPAPI_API_KEY=your_serpapi_key_here

# ================================
# Qdrant 向量数据库配置 - 获取API密钥：https://cloud.qdrant.io/
# ================================
# 使用Qdrant云服务 (推荐)
QDRANT_URL=https://your-cluster.qdrant.tech:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# 或使用本地Qdrant (需要Docker)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# Qdrant集合配置
QDRANT_COLLECTION=hello_agents_vectors
QDRANT_VECTOR_SIZE=384
QDRANT_DISTANCE=cosine
QDRANT_TIMEOUT=30

# ================================
# Neo4j 图数据库配置 - 获取API密钥：https://neo4j.com/cloud/aura/
# ================================
# 使用Neo4j Aura云服务 (推荐)
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# 或使用本地Neo4j (需要Docker)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=hello-agents-password

# Neo4j连接配置
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=60

# ==========================
# 嵌入（Embedding）配置示例 - 可从阿里云控制台获取：https://dashscope.aliyun.com/
# ==========================
# - 若为空，dashscope 默认 text-embedding-v3；local 默认 sentence-transformers/all-MiniLM-L6-v2
EMBED_MODEL_TYPE=dashscope
EMBED_MODEL_NAME=
EMBED_API_KEY=
EMBED_BASE_URL=

# ================================
# GitHub API 配置
# ================================
# GitHub Personal Access Token - 用于访问GitHub API
# 获取方式：https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=

# ================================
# HuggingFace API 配置
# ================================
# HuggingFace Token - 用于访问gated datasets (如GAIA)
# 获取方式：https://huggingface.co/settings/tokens
HF_TOKEN=

# ============================================================================
# HelloAgents Learn self-host 平台配置（Platform Stage 1）
# ============================================================================
APP_NAME=HelloAgents Learn
ENVIRONMENT=development
BIND_ADDRESS=127.0.0.1
API_PORT=8000
WEB_PORT=8080
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

POSTGRES_DB=hello_agents
POSTGRES_USER=hello_agents
POSTGRES_PASSWORD=hello_agents
POSTGRES_PORT=55432
QDRANT_PORT=6333
REDIS_PORT=6379

# Platform Stage 2 embedding provider (DashScope by default)
PRODUCT_EMBEDDING_PROVIDER=dashscope
PRODUCT_EMBEDDING_MODEL=text-embedding-v4
PRODUCT_EMBEDDING_DIMENSION=1024
PRODUCT_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/text-embedding/text-embedding
INGESTION_LEASE_SECONDS=120
INGESTION_HEARTBEAT_SECONDS=30
INGESTION_MAX_ATTEMPTS=3
INGESTION_RECONCILE_SECONDS=30
PRODUCT_EMBEDDING_API_KEY=

# Platform Stage 2 Slice 2 batch/parser budgets
BATCH_MAX_FILES=20
BATCH_MAX_BYTES=104857600
PDF_MAX_PAGES=500
PARSED_TEXT_MAX_CHARS=1000000
DOCUMENT_MAX_CHUNKS=2000
DOCUMENT_EMBEDDING_MAX_TOKENS=1500000
PARSER_TIMEOUT_SECONDS=600
WORKSPACE_MAX_ACTIVE_INGESTIONS=3
PRODUCT_RAG_DEFAULT_TOP_K=5
PRODUCT_RAG_CANDIDATE_MULTIPLIER=3
PRODUCT_RAG_CANDIDATE_CAP=50
# Conservative semantic fallback. Literal document/title/chunk matches remain valid below it.
PRODUCT_RAG_MIN_SCORE=0.50

# Platform Stage 2 Slice 2 cited-answer generation (DeepSeek official API)
PRODUCT_GENERATION_PROVIDER=deepseek
PRODUCT_GENERATION_MODEL=deepseek-v4-flash
PRODUCT_GENERATION_BASE_URL=https://api.deepseek.com
PRODUCT_GENERATION_API_KEY=
LESSON_GENERATION_MAX_EVIDENCE_TOKENS=48000
LESSON_GENERATION_MAX_OUTPUT_TOKENS_PER_CALL=8000
LESSON_GENERATION_MAX_TOTAL_OUTPUT_TOKENS=32000
LESSON_GENERATION_MAX_PROVIDER_CALLS=12
LESSON_GENERATION_MAX_COVERAGE_UNITS=8
LESSON_GENERATION_TIMEOUT_SECONDS=180
LESSON_GENERATION_MAX_WALL_SECONDS=1200
PRODUCT_GENERATION_TIMEOUT_SECONDS=45
PRODUCT_GENERATION_THINKING=false
PRODUCT_GENERATION_MAX_EVIDENCE_TOKENS=12000
PRODUCT_GENERATION_MAX_OUTPUT_TOKENS=1500
